# --- POLYMARKET / WALLET ---

# Privata nyckeln för walleten som äger CLOB-kontot (Polygon mainnet).
# Format: 0x... (HÅLL HEMLIGT – lägg aldrig upp .env!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# (Valfritt) separat settler-nyckel / extra plånbok
SETTLER_PRIVATE_KEY=
POLYGON_WALLET_PRIVATE_KEY=

# Funder = proxy-adress (där saldot ligger). Hitta den på polymarket.com/settings.
# https://docs.polymarket.com/api-reference/authentication
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS_HERE

POLYGON_CONFIG_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Signature type (https://docs.polymarket.com/trading/overview#signature-types):
# 0 = EOA (standalone wallet), 1 = POLY_PROXY (Magic/email), 2 = GNOSIS_SAFE (MetaMask + deposit – vanligast)
POLYGON_SIGNATURE_TYPE=2

# --- POLYMARKET CLOB USER API (L2) ---
# Fylls i via scripts/python/create_polymarket_api_creds.py
# Sätt POLYMARKET_FORCE_NEW_API_KEY=1 för att skapa ny nyckel (nonce från chain) – test vid invalid signature
# Sätt MAGNUS_VERIFY_CLOB_PAYLOAD=1 för att logga exakt payload till verify-clob-payload.jsonl (verifiera vad som skickas)
USER_API_KEY=YOUR_CLOB_API_KEY
USER_API_SECRET=YOUR_CLOB_API_SECRET
USER_API_PASSPHRASE=YOUR_CLOB_API_PASSPHRASE


# --- AI / EXTERNA API-KEYS ---

OPENAI_API_KEY=your_openai_key_here
TAVILY_API_KEY=your_tavily_key_here
NEWSAPI_API_KEY=your_newsapi_key_here
XAI_API_KEY=your_xai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here


# --- SYSTEM SETTINGS ---

DB_PATH=./data/magnus_v3.db
CHROMA_PATH=./data/chroma_db
LOG_LEVEL=INFO


# --- MAGNUS BETEENDE / RISK ---

# Osäker marknad: strängare edge, färre positioner (0 eller 1)
MAGNUS_UNCERTAIN_MARKET=0

# Drawdown: pausa nya köp när USDC-saldo fallit X% från peak (100 = i praktiken av)
MAGNUS_MAX_DRAWDOWN_PCT=100

# Max antal positioner i samma kategori innan vi skippar ny köpkandidat
MAGNUS_MAX_CORRELATED=5


# --- SCANNER ---

# 1 = debug: visa price-skip-värden + en rad per event (stäng av i prod)
MAGNUS_VERBOSE_SCANNER=0

# Sekunder mellan scannerrundor (t.ex. 900 = 15 min)
# MAGNUS_SCAN_INTERVAL_SECONDS=900
# Strategier: liquid, undiscovered, new, trending, featured. Default: liquid,undiscovered,new (undvik trending – redan pumpade)
# MAGNUS_SCANNER_STRATEGIES=liquid,undiscovered,new

# Sekunder innan samma marknad får komma in i kön igen
# MAGNUS_DEDUP_TTL_SECONDS=3600

# 1 = skippa Bouncer i scannern, fler kandidater till War Room
MAGNUS_SKIP_BOUNCER_IN_SCANNER=1

# Återhandla marknad efter N dagar (0 = aldrig)
MAGNUS_ALLOW_RETRADE_AFTER_DAYS=0

# Min dagar kvar till resolution för köp (0.2 = ~5h, 0.1 = ~2.5h – esport BO3)
# MAGNUS_MIN_DAYS_TO_BUY=0.1

# Min volatilitet (range %) i scannern – 0 = kräv inte
# MAGNUS_MIN_RANGE_PCT=0

# Min budlikviditet USDC
MAGNUS_MIN_BID_LIQUIDITY=1


# --- WAR ROOM / KÖP ---

# Min förväntad brutto‑profit (USDC) för att lägga order – sänk (t.ex. 0.05) så fler BUY blir ordrar
# MAGNUS_MIN_GROSS_PROFIT_USDC=0.05

# 0 = kräv inte pris under snitt (fler köp)
# MAGNUS_REQUIRE_BELOW_AVG=0

# Min edge för köp (0.018 = 1.8¢, 0.025 = 2.5¢)
# MAGNUS_MIN_EDGE=0.018

# Max köppris – måste finnas utrymme för vinst inkl. avgifter. 0.6 = max 40¢/andel.
# MAGNUS_MAX_BUY_PRICE=0.6

# 1 = endast FOK (direkt fill), skippa GTC. Default 1. Sätt 0 för att tillåta maker BUY (GTC).
MAGNUS_BUY_FOK_ONLY=1

# Max prisrörelse under analys innan vi skippar (default 0.02 = 2¢). Lägre = snabbare skippa vid stigning.
# MAGNUS_PRICE_MOVE_TOLERANCE=0.02

# Mindre batch = snabbare till köp (default 4). Resultat processas direkt vid completion.
# MAGNUS_WAR_ROOM_BATCH_SIZE=4
# 1 = skippa Tavily/NewsAPI (sparar 5–15s per marknad – rekommenderas för snabbare köp)
# MAGNUS_SKIP_RESEARCH=1

# Min insats USDC – Polymarket kräver minst $1; vi använder också minst 5 andelar (sälj-spärr)
# MAGNUS_MIN_BET_USDC=1.0

# Min andel av saldo per godkänt köp (0.08 = 8%)
# MAGNUS_MIN_BET_PCT_BALANCE=0.08

# 1 = skippa Lawyer (sparar tokens, fler når Quant)
MAGNUS_SKIP_LAWYER=1

# Modeller (kan lämnas tomma för default i kod)
# MAGNUS_MODEL_BOUNCER=grok-3-mini
# MAGNUS_MODEL_SCOUT=grok-4-1-fast-non-reasoning
# MAGNUS_MODEL_LAWYER=claude-sonnet-4-20250514
# deepseek-chat = snabbare än deepseek-reasoner (mindre noggrann men ~10–20s snabbare)
# MAGNUS_MODEL_QUANT=deepseek-chat


# --- TRADE / STOP-LOSS ---

# Timmar innan stop-loss aktiveras
# MAGNUS_MIN_HOLD_HOURS=2.0

# Shadow mode recovery
# MAGNUS_EXIT_SHADOW_MODE=1
# MAGNUS_RECOVERY_HIGH_MIN_DAYS=1.0
# MAGNUS_RECOVERY_HIGH_MIN_RANGE=15
# MAGNUS_RECOVERY_LOW_MAX_DAYS=0.5
# MAGNUS_RECOVERY_LOW_MAX_RANGE=10


# --- DASHBOARD ---

# MAGNUS_DASHBOARD_PORT=8877

