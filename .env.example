# --- POLYMARKET / WALLET ---

# Private key for wallet that owns CLOB account (Polygon mainnet).
# Format: 0x... (KEEP SECRET – never publish .env!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# (Optional) separate settler key / extra wallet
SETTLER_PRIVATE_KEY=
POLYGON_WALLET_PRIVATE_KEY=

# Funder = proxy address (where balance sits). Find it at polymarket.com/settings.
# https://docs.polymarket.com/api-reference/authentication
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS_HERE

POLYGON_CONFIG_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Signature type (https://docs.polymarket.com/trading/overview#signature-types):
# 0 = EOA (standalone wallet), 1 = POLY_PROXY (Magic/email), 2 = GNOSIS_SAFE (MetaMask + deposit – most common)
POLYGON_SIGNATURE_TYPE=2

# --- POLYMARKET CLOB USER API (L2) ---
# Fill in via scripts/python/create_polymarket_api_creds.py
# Set POLYMARKET_FORCE_NEW_API_KEY=1 to create new key (nonce from chain) – test for invalid signature
# Set MAGNUS_VERIFY_CLOB_PAYLOAD=1 to log exact payload to verify-clob-payload.jsonl (verify what is sent)
USER_API_KEY=YOUR_CLOB_API_KEY
USER_API_SECRET=YOUR_CLOB_API_SECRET
USER_API_PASSPHRASE=YOUR_CLOB_API_PASSPHRASE


# --- AI / EXTERNAL API KEYS ---

OPENAI_API_KEY=your_openai_key_here
TAVILY_API_KEY=your_tavily_key_here
NEWSAPI_API_KEY=your_newsapi_key_here
XAI_API_KEY=your_xai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here


# --- SYSTEM SETTINGS ---

DB_PATH=./data/magnus_v3.db
CHROMA_PATH=./data/chroma_db
LOG_LEVEL=INFO


# --- MAGNUS BEHAVIOUR / RISK ---

# Uncertain market: stricter edge, fewer positions (0 or 1)
MAGNUS_UNCERTAIN_MARKET=0

# Drawdown: pause new buys when USDC balance has fallen X% from peak (100 = effectively off)
MAGNUS_MAX_DRAWDOWN_PCT=100

# Max positions in same category before we skip new buy candidate
MAGNUS_MAX_CORRELATED=5


# --- SCANNER ---

# 1 = debug: show price-skip values + one line per event (turn off in prod)
MAGNUS_VERBOSE_SCANNER=0

# Seconds between scanner rounds (e.g. 900 = 15 min)
# MAGNUS_SCAN_INTERVAL_SECONDS=900
# Strategies: liquid, undiscovered, new, trending, featured. Default: liquid,undiscovered,new (avoid trending – already pumped)
# MAGNUS_SCANNER_STRATEGIES=liquid,undiscovered,new

# Seconds before same market can re-enter queue
# MAGNUS_DEDUP_TTL_SECONDS=3600

# 1 = skip Bouncer in scanner, more candidates to War Room
MAGNUS_SKIP_BOUNCER_IN_SCANNER=1

# Re-trade market after N days (0 = never)
MAGNUS_ALLOW_RETRADE_AFTER_DAYS=0

# Min days left to resolution for buy (0.2 = ~5h, 0.1 = ~2.5h – esport BO3)
# MAGNUS_MIN_DAYS_TO_BUY=0.1

# Min volatility (range %) in scanner – 0 = do not require
# MAGNUS_MIN_RANGE_PCT=0

# Min bid liquidity USDC
MAGNUS_MIN_BID_LIQUIDITY=1


# --- WAR ROOM / BUY ---

# Min expected gross profit (USDC) to place order – lower (e.g. 0.05) so more BUYs become orders
# MAGNUS_MIN_GROSS_PROFIT_USDC=0.05

# 0 = do not require price below average (more buys)
# MAGNUS_REQUIRE_BELOW_AVG=0

# Min edge for buy (0.018 = 1.8¢, 0.025 = 2.5¢)
# MAGNUS_MIN_EDGE=0.018

# Max buy price – must be room for profit incl. fees. 0.6 = max 40¢/share.
# MAGNUS_MAX_BUY_PRICE=0.6

# 1 = FOK only (direct fill), skip GTC. Default 1. Set 0 to allow maker BUY (GTC).
MAGNUS_BUY_FOK_ONLY=1

# Max price move during analysis before we skip (default 0.02 = 2¢). Lower = faster skip on rise.
# MAGNUS_PRICE_MOVE_TOLERANCE=0.02

# Smaller batch = faster to buy (default 4). Results processed directly on completion.
# MAGNUS_WAR_ROOM_BATCH_SIZE=4
# 1 = skip Tavily/NewsAPI (saves 5–15s per market – recommended for faster buy)
# MAGNUS_SKIP_RESEARCH=1

# Min bet USDC – Polymarket requires at least $1; we also use min 5 shares (sell gate)
# MAGNUS_MIN_BET_USDC=1.0

# Min share of balance per approved buy (0.08 = 8%)
# MAGNUS_MIN_BET_PCT_BALANCE=0.08

# 1 = skip Lawyer (saves tokens, more reach Quant)
MAGNUS_SKIP_LAWYER=1

# Models (can leave empty for default in code)
# MAGNUS_MODEL_BOUNCER=grok-3-mini
# MAGNUS_MODEL_SCOUT=grok-4-1-fast-non-reasoning
# MAGNUS_MODEL_LAWYER=claude-sonnet-4-20250514
# deepseek-chat = faster than deepseek-reasoner (less accurate but ~10–20s faster)
# MAGNUS_MODEL_QUANT=deepseek-chat


# --- TRADE / STOP-LOSS ---

# Hours before stop-loss activates
# MAGNUS_MIN_HOLD_HOURS=2.0

# Shadow mode recovery
# MAGNUS_EXIT_SHADOW_MODE=1
# MAGNUS_RECOVERY_HIGH_MIN_DAYS=1.0
# MAGNUS_RECOVERY_HIGH_MIN_RANGE=15
# MAGNUS_RECOVERY_LOW_MAX_DAYS=0.5
# MAGNUS_RECOVERY_LOW_MAX_RANGE=10


# --- DASHBOARD ---

# MAGNUS_DASHBOARD_PORT=8877
